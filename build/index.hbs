<!-- ── HEADER ─────────────────────────────────────────────── -->
<header class="sticky top-0 z-50 bg-cream/80 border-b border-sand/50">
  <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
    <div class="font-serif text-2xl font-bold tracking-tight text-espresso">
      Maggie Muldoon
    </div>
    <nav class="hidden md:flex gap-8 text-sm font-medium uppercase tracking-widest text-taupe">
      <a href="#services"  class="hover:text-copper transition-colors">Services</a>
      <a href="#contact"   class="hover:text-copper transition-colors">Contact</a>
    </nav>
    <a href="#contact"
       class="btn btn-primary hidden md:inline-flex px-8 py-3 text-sm">
      Book Now
    </a>
  </div>
</header>

<!-- ── HERO ───────────────────────────────────────────────── -->
<section class="relative px-6 pt-16 pb-24 md:pt-32 md:pb-40 overflow-hidden bg-cream">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">

    <!-- Text -->
    <div class="max-w-xl">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-linen text-bronze text-xs font-semibold uppercase tracking-widest mb-6">
        <i data-lucide="paintbrush" class="w-3 h-3"></i>
        Live Event Artist
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold leading-tight mb-6 text-espresso">
        Capturing your most
        beautiful moments,
        <em class="text-copper font-light not-italic">live.</em>
      </h1>
      <p class="text-lg md:text-xl text-taupe mb-10 leading-relaxed">
        I bring weddings, corporate events, and private parties to life through live painting.
        Watch your memories become timeless art right before your eyes.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="#contact" class="btn btn-primary px-8 py-4 text-base">
          Inquire for your date
        </a>
      </div>
    </div>

    <!-- Image -->
    <div class="relative">
      <div class="absolute inset-0 bg-sand hero-shape transform translate-x-4 translate-y-4"></div>
      <img src="/images/hero.jpg"
           alt="Live artist painting at a wedding reception"
           class="relative z-10 w-full object-cover hero-shape hero-shadow"
           style="aspect-ratio:4/5; max-height:580px;">
    </div>
  </div>
</section>

<!-- ── ARTWORK CAROUSEL ────────────────────────────────────── -->
