    <!-- Artwork grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      <div class="portfolio-image-container">
        <img src="/images/artwork/navajo-bridge.jpg" alt="Navajo Bridge Plein Air">
        <div class="portfolio-overlay"></div>
        <div class="portfolio-caption">
          <h3 class="font-serif text-base font-semibold">Navajo Bridge</h3>
          <p class="text-xs text-white/80">Plein Air</p>
        </div>
      </div>
      <div class="portfolio-image-container">
        <img src="/images/artwork/sonoma.jpg" alt="Sonoma">
        <div class="portfolio-overlay"></div>
        <div class="portfolio-caption">
          <h3 class="font-serif text-base font-semibold">Sonoma</h3>
          <p class="text-xs text-white/80">Plein Air, 9×12"</p>
        </div>
      </div>
      <div class="portfolio-image-container">
        <img src="/images/artwork/south-street-seaport.png" alt="South Street Seaport">
        <div class="portfolio-overlay"></div>
        <div class="portfolio-caption">
          <h3 class="font-serif text-base font-semibold">South Street Seaport</h3>
          <p class="text-xs text-white/80">Plein Air, 9×12"</p>
        </div>
      </div>
      <div class="portfolio-image-container">
        <img src="/images/artwork/liberian-girl.png" alt="Liberian Girl">
        <div class="portfolio-overlay"></div>
        <div class="portfolio-caption">
          <h3 class="font-serif text-base font-semibold">Liberian Girl</h3>
          <p class="text-xs text-white/80">16×24"</p>
        </div>
      </div>
    </div>

    <!-- Big CTA button -->
    <div class="text-center mt-14">
      <a href="https://maggiemuldoon.com"
         target="_blank" rel="noopener noreferrer"
         class="btn-website-cta">
        See the full collection at maggiemuldoon.com
        <i data-lucide="arrow-right" class="w-5 h-5 ml-2 inline-block"></i>
      </a>
    </div>
  </div>
</section>

<!-- ── SERVICES ───────────────────────────────────────────── -->
<section id="services" class="py-24 px-6 relative dot-bg">
  <div class="absolute inset-0 opacity-40 pointer-events-none dot-bg"></div>
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="text-center mb-16">
      <h2 class="font-serif text-4xl md:text-5xl font-bold text-espresso mb-4">Live Art Services</h2>
      <p class="text-taupe max-w-2xl mx-auto text-lg">Unique entertainment that leaves you with a masterpiece.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <!-- Weddings -->
      <div class="service-card p-8">
        <div class="icon-badge mb-6">
          <i data-lucide="palette" class="w-7 h-7 text-copper"></i>
        </div>
        <h3 class="font-serif text-xl font-bold mb-3 text-espresso">Live Weddings</h3>
        <p class="text-taupe text-sm leading-relaxed">
          A bespoke oil painting of your ceremony or reception, created live as guests mingle and celebrate.
        </p>
      </div>

      <!-- Guest Portraits -->
      <div class="service-card p-8">
        <div class="icon-badge mb-6">
          <i data-lucide="camera" class="w-7 h-7 text-copper"></i>
        </div>
        <h3 class="font-serif text-xl font-bold mb-3 text-espresso">Guest Portraits</h3>
        <p class="text-taupe text-sm leading-relaxed">
          Quick, elegant watercolor or sketch portraits for your guests to take home as one-of-a-kind favors.
        </p>
      </div>

      <!-- Landscape Painting -->
      <div class="service-card p-8">
        <div class="icon-badge mb-6">
          <i data-lucide="mountain" class="w-7 h-7 text-copper"></i>
        </div>
        <h3 class="font-serif text-xl font-bold mb-3 text-espresso">Landscape Painting</h3>
        <p class="text-taupe text-sm leading-relaxed">
          Capturing the beauty of your venue or destination setting in a rich, impressionist plein air style.
        </p>
      </div>

      <!-- Face Painting -->
      <div class="service-card overflow-hidden p-0 flex flex-col">
        <div class="h-40 overflow-hidden">
          <img src="/images/face-painting.png"
               alt="Child getting face painted as a butterfly"
               class="w-full h-full object-cover">
        </div>
        <div class="p-6 flex-1">
          <h3 class="font-serif text-xl font-bold mb-3 text-espresso">Face Painting</h3>
          <p class="text-taupe text-sm leading-relaxed">
            High-end, intricate face and body art for children's parties or themed adult events.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

