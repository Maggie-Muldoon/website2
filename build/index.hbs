        Live Event Artist
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold leading-tight mb-6 text-espresso">
        Capturing your most
        beautiful moments,
        <em class="text-copper font-light not-italic">live.</em>
      </h1>
      <p class="text-lg md:text-xl text-taupe mb-10 leading-relaxed">
        I bring weddings, corporate events, and private parties to life through live painting.
        Watch your memories become timeless art right before your eyes.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="#contact" class="btn btn-primary px-8 py-4 text-base">
          Inquire for your date
        </a>
      </div>
    </div>

    <!-- Image -->
    <div class="relative">
      <div class="absolute inset-0 bg-sand hero-shape transform translate-x-4 translate-y-4"></div>
      <img src="/images/hero.jpg"
           alt="Live artist painting at a wedding reception"
           class="relative z-10 w-full object-cover hero-shape hero-shadow"
           style="aspect-ratio:4/5; max-height:580px;">
    </div>
  </div>
</section>

<!-- ── SERVICES ───────────────────────────────────────────── -->
<section id="services" class="py-24 px-6 relative dot-bg">
  <div class="absolute inset-0 opacity-40 pointer-events-none dot-bg"></div>
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="text-center mb-16">
      <h2 class="font-serif text-4xl md:text-5xl font-bold text-espresso mb-4">Live Art Services</h2>
      <p class="text-taupe max-w-2xl mx-auto text-lg">Unique entertainment that leaves you with a masterpiece.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">

      <!-- Live Event Painting -->
      <div class="service-card p-8">
        <div class="icon-badge mb-6">
          <i data-lucide="palette" class="w-7 h-7 text-copper"></i>
        </div>
        <h3 class="font-serif text-xl font-bold mb-3 text-espresso">Live Event Painting</h3>
        <p class="text-taupe text-sm leading-relaxed">
          A large-format painting created live at your event — corporate, private, or public — as guests watch and mingle.
        </p>
      </div>

      <!-- Wedding Art -->
      <div class="service-card p-8">
        <div class="icon-badge mb-6">
          <i data-lucide="heart" class="w-7 h-7 text-copper"></i>
        </div>
        <h3 class="font-serif text-xl font-bold mb-3 text-espresso">Wedding Art</h3>
        <p class="text-taupe text-sm leading-relaxed">
          A bespoke painting of your ceremony or reception, capturing the atmosphere and emotion of your day as it unfolds.
        </p>
      </div>

      <!-- Quick Portraits -->
      <div class="service-card overflow-hidden p-0 flex flex-col">
        <div class="h-40 overflow-hidden">
          <img src="/images/quick-portraits.jpg"
               alt="Guest holding her quick portrait painting"
               class="w-full h-full object-cover">
        </div>
        <div class="p-6 flex-1">
          <h3 class="font-serif text-xl font-bold mb-3 text-espresso">Quick Portraits</h3>
          <p class="text-taupe text-sm leading-relaxed">
            Speedy, expressive portraits of guests done live — a unique and memorable takeaway from your event.
          </p>
        </div>
      </div>

      <!-- Face & Body Painting -->
      <div class="service-card p-8">
        <div class="icon-badge mb-6">
          <i data-lucide="sparkles" class="w-7 h-7 text-copper"></i>
        </div>
        <h3 class="font-serif text-xl font-bold mb-3 text-espresso">Face &amp; Body Painting</h3>
        <p class="text-taupe text-sm leading-relaxed">
          High-end, intricate face and body art for children's parties, festivals, and themed adult events.
        </p>
      </div>

      <!-- Art Events & Workshops -->
      <div class="service-card p-8">
        <div class="icon-badge mb-6">
          <i data-lucide="brush" class="w-7 h-7 text-copper"></i>
        </div>
        <h3 class="font-serif text-xl font-bold mb-3 text-espresso">Art Events &amp; Workshops</h3>
        <p class="text-taupe text-sm leading-relaxed">
          Interactive painting sessions and guided workshops that get your guests creating alongside a professional artist.
        </p>
      </div>

    </div>
  </div>
</section>

